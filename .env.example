DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/threex
CORS_ORIGINS=["http://localhost:3000"]
API_INTERNAL_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
LLM_SCORER_PROVIDER=heuristic
DOMAIN_SCORER_MODEL_DIR=models/news_scorer_lora
JWT_SECRET=change-me-in-production
DEMO_USER_EMAIL=demo@3x.local
DEMO_USER_PASSWORD=demo-password
LOG_LEVEL=INFO
OTEL_SERVICE_NAME=3x-api
# Leave unset for console span export; set to an OTLP collector endpoint such as http://otel-collector:4317 in deployment.
OTEL_EXPORTER_OTLP_ENDPOINT=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DATA_PER_MINUTE=60
RATE_LIMIT_RISK_ASSESSMENT_PER_MINUTE=10
RATE_LIMIT_SENSITIVITY_PER_MINUTE=5
