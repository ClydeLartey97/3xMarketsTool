ENVIRONMENT=development
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/threex
CORS_ORIGINS=["http://localhost:3000"]
API_INTERNAL_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_BASE_URL=/api/backend
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
API_BEARER_TOKEN=
SERVER_AUTO_LOGIN=true
LLM_SCORER_PROVIDER=heuristic
DOMAIN_SCORER_MODEL_DIR=models/news_scorer_lora
JWT_SECRET=replace-with-at-least-32-random-characters
DEMO_USER_EMAIL=demo@3x.local
DEMO_USER_PASSWORD=replace-with-a-non-default-password
ALLOW_REGISTRATION=false
AUDIT_EXPORT_ROLES=["admin","auditor"]
LOG_LEVEL=INFO
OTEL_SERVICE_NAME=3x-api
# Set to an OTLP collector endpoint such as http://otel-collector:4317 in deployment.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_CONSOLE_EXPORTER=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DATA_PER_MINUTE=60
RATE_LIMIT_RISK_ASSESSMENT_PER_MINUTE=10
RATE_LIMIT_SENSITIVITY_PER_MINUTE=5
