{
  "name": "threex-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "start:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next build && next start -p 3000",
    "lint": "eslint app components lib types --max-warnings=0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "klinecharts": "^9.8.12",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.15",
    "postcss": "8.5.12",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "lodash": "4.18.1",
    "picomatch": "4.0.4",
    "postcss": "8.5.12"
  }
