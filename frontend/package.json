{
  "name": "threex-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build && next start --hostname 127.0.0.1 -p 3000",
    "dev:hot": "next dev --webpack --hostname 127.0.0.1 -p 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && npm run dev",
    "build": "next build --webpack",
    "start": "next start --hostname 127.0.0.1 -p 3000",
    "start:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next build --webpack && next start --hostname 127.0.0.1 -p 3000",
    "lint": "eslint app components lib types --max-warnings=0 --cache --cache-location node_modules/.cache/eslint/",
    "lint:nocache": "eslint app components lib types --max-warnings=0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "klinecharts": "^9.8.12",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "powerbi-client": "^2.23.10",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-resizable-panels": "^2.1.9"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.11",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.12",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "lodash": "4.18.1",
    "picomatch": "4.0.4",
    "postcss": "8.5.12"
  }
}
